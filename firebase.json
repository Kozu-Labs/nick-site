{
  "hosting": {
    "target": "nick-site",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "/portal/**",
        "headers": [
          { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
        ]
      },
      {
        "source": "/portals/**",
        "headers": [
          { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/api/submitContact",  "function": { "functionId": "submitContact",  "region": "us-central1" } },
      { "source": "/api/portal/login",    "function": { "functionId": "portalLogin",    "region": "us-central1" } },
      { "source": "/api/portal/data",     "function": { "functionId": "portalData",     "region": "us-central1" } },
      { "source": "/api/portal/download", "function": { "functionId": "portalDownload", "region": "us-central1" } },
      { "source": "/api/portal/event",    "function": { "functionId": "portalEvent",    "region": "us-central1" } },
      { "source": "/api/portal/logout",   "function": { "functionId": "portalLogout",   "region": "us-central1" } }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
