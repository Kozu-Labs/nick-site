{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git remote:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(firebase deploy:*)",
      "Bash(firebase functions:*)",
      "Bash(firebase hosting:*)",
      "Bash(firebase projects:*)",
      "Bash(npx firebase-tools:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(curl -I:*)",
      "Bash(curl -s:*)",
      "Bash(cp ~/NS.md:*)",
      "Bash(chmod +x:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/on-stop-deploy.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
